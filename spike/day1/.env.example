# Phala Redpill API key
# Get yours from: https://phala.com/ → Cloud Dashboard → API Keys
REDPILL_API_KEY=your_phala_redpill_api_key_here

# Phala Redpill API endpoint (OpenAI-compatible)
REDPILL_BASE_URL=https://api.redpill.ai/v1

# Model to use for the spike. Strongest for code per recent benchmarks.
# Other options: Qwen/Qwen3.5-Coder-Next ($0.30/M input; cheaper),
# zai-org/glm-5.1 ($0.10/M input; cheapest).
# Verify the exact model ID against Phala Redpill docs / dashboard if this fails.
REDPILL_MODEL=moonshotai/Kimi-K2-6
