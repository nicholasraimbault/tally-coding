# Copy this file to scripts/.env and paste your keys.
# scripts/.env is gitignored — your secrets stay local.

# Required: Red Pill API key (for TEE-attested LLM inference via api.redpill.ai)
# Get from: https://redpill.ai/dashboard → API Keys
# NOTE: Red Pill is a separate product from Phala Cloud (operated by Hashforest
# Technology LLC, powered by Phala TEE infrastructure). Phala Cloud keys do NOT
# work here — you need to sign up at redpill.ai separately.
REDPILL_API_KEY=

# Optional: Phala Cloud API key (for `phala deploy` without browser login)
# If unset, the script will prompt you to run `phala login` once.
# Get from: https://cloud.phala.network → API Tokens
# (Different account, different dashboard from Red Pill above.)
PHALA_CLOUD_API_KEY=

# Optional overrides (use defaults if blank)
REDPILL_BASE_URL=https://api.redpill.ai/v1
REDPILL_MODEL=moonshotai/Kimi-K2-6

# Optional: customize the Tally Workers test team_id prefix
# (script appends a random suffix per run for isolation)
TEAM_ID_PREFIX=tally-coding-runner

# Auth that's already configured — leave as-is unless you have custom values
TALLY_WORKERS_URL=https://tally.nraimbault16.workers.dev
